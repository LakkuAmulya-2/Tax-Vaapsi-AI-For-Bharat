# Tax Vaapsi v3.0 - Environment Configuration
# Copy this to .env and fill in your AWS credentials

# ─── AWS CREDENTIALS ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=ap-south-1

# ─── AWS BEDROCK ─────────────────────────────────────────────
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0
BEDROCK_REGION=ap-south-1

# ─── AWS BEDROCK AGENT IDs (fill after running /api/bedrock/create-agents) ─
BEDROCK_GST_AGENT_ID=
BEDROCK_GST_AGENT_ALIAS_ID=
BEDROCK_IT_AGENT_ID=
BEDROCK_IT_AGENT_ALIAS_ID=
BEDROCK_NOTICE_AGENT_ID=
BEDROCK_NOTICE_AGENT_ALIAS_ID=
BEDROCK_SUPERVISOR_AGENT_ID=
BEDROCK_SUPERVISOR_AGENT_ALIAS_ID=

# ─── AWS DYNAMODB ────────────────────────────────────────────
DYNAMODB_TABLE_PREFIX=taxvaapsi_
USE_LOCAL_DYNAMODB=true
DYNAMODB_ENDPOINT_URL=http://localhost:8000

# ─── AWS S3 ──────────────────────────────────────────────────
S3_BUCKET_NAME=taxvaapsi-documents
S3_REGION=ap-south-1

# ─── AWS SQS ─────────────────────────────────────────────────
SQS_GST_QUEUE_URL=
SQS_IT_QUEUE_URL=
SQS_NOTICE_QUEUE_URL=

# ─── AWS STEP FUNCTIONS ──────────────────────────────────────
SFN_GST_WORKFLOW_ARN=
SFN_IT_WORKFLOW_ARN=

# ─── AWS SNS ─────────────────────────────────────────────────
SNS_TOPIC_ARN=

# ─── MCP SERVERS ─────────────────────────────────────────────
MCP_GST_SERVER_PORT=9101
MCP_IT_SERVER_PORT=9102
MCP_TAX_LAW_SERVER_PORT=9103

# ─── DUMMY PORTALS ───────────────────────────────────────────
GST_PORTAL_URL=http://localhost:8001
IT_PORTAL_URL=http://localhost:8002
